@{
    ViewBag.Title = "Pagina de Inicio";
}

@{
    ViewBag.Title = "Inicio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .hero {
        background: linear-gradient(to right, #007bff, #6610f2);
        color: white;
        padding: 100px 30px;
        text-align: center;
        border-radius: 15px;
        margin: 30px auto;
        max-width: 1000px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.2);
    }

        .hero h1 {
            font-size: 3em;
            margin-bottom: 20px;
            font-weight: bold;
        }

        .hero p {
            font-size: 1.3em;
            margin-bottom: 30px;
        }

        .hero a.btn {
            background-color: #ffc107;
            color: #000;
            padding: 12px 25px;
            font-size: 1.1em;
            font-weight: bold;
            border-radius: 8px;
            text-decoration: none;
            transition: background-color 0.3s ease;
        }

            .hero a.btn:hover {
                background-color: #e0a800;
                color: white;
            }
</style>

<div class="hero">
    <h1>Bienvenido a CounterTex</h1>
    <p>Gestión completa de producción y finanzas para tu empresa textil</p>
    <a class="btn" href="/Cuenta/Login">Iniciar Sesión</a>
</div>
