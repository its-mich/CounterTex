@{
    ViewBag.Title = "Chat Interno";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .chat-container {
        max-width: 700px;
        margin: 50px auto;
        background-color: #f7f7f7;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0px 0px 15px rgba(0, 0, 0, 0.2);
    }

    .chat-box {
        height: 300px;
        overflow-y: auto;
        padding: 15px;
        border: 1px solid #ccc;
        margin-bottom: 20px;
        background-color: #fff;
        border-radius: 10px;
    }

    .chat-message {
        margin-bottom: 10px;
        padding: 8px 12px;
        border-radius: 10px;
        background-color: #e2e2ff;
    }

    .chat-input {
        display: flex;
        gap: 10px;
    }

        .chat-input input {
            flex: 1;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #ccc;
        }

        .chat-input button {
            padding: 10px 20px;
            background-color: #007bff;
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
        }

            .chat-input button:hover {
                background-color: #0056b3;
            }
</style>

<div class="chat-container">
    <h2 class="text-center mb-4">Chat Interno</h2>

    <div class="chat-box" id="chatBox">
        <div class="chat-message">[Carlos]: Hola, ¿cómo va la producción?</div>
        <div class="chat-message">[Laura]: Todo en orden, ya casi terminamos.</div>
    </div>

    <form class="chat-input" id="chatForm">
        <input type="text" id="mensaje" placeholder="Escribe tu mensaje..." required />
        <button type="submit">Enviar</button>
    </form>
</div>

<script>
    const chatForm = document.getElementById("chatForm");
    const chatBox = document.getElementById("chatBox");

    chatForm.addEventListener("submit", function (e) {
        e.preventDefault();
        const input = document.getElementById("mensaje");
        const mensaje = input.value.trim();
        if (mensaje) {
            const nuevoMensaje = document.createElement("div");
            nuevoMensaje.className = "chat-message";
            nuevoMensaje.textContent = `[Tú]: ${mensaje}`;
            chatBox.appendChild(nuevoMensaje);
            input.value = "";
            chatBox.scrollTop = chatBox.scrollHeight;
        }
    });
</script>


