@{
    ViewBag.Title = "Producción Mensual";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .mensual-container {
        max-width: 950px;
        margin: 60px auto;
        background-color: #ffffff;
        padding: 30px;
        border-radius: 15px;
        box-shadow: 0 0 15px rgba(0,0,0,0.1);
    }

        .mensual-container h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #17a2b8;
        }

    table {
        width: 100%;
        border-collapse: collapse;
        background-color: #f8f9fa;
        border-radius: 10px;
        overflow: hidden;
    }

    thead {
        background-color: #17a2b8;
        color: white;
    }

    th, td {
        padding: 12px;
        text-align: center;
        border-bottom: 1px solid #ddd;
    }

    tr:hover {
        background-color: #e9ecef;
    }

    .resumen-total {
        margin-top: 25px;
        font-weight: bold;
        text-align: right;
        color: #333;
    }
</style>

<div class="mensual-container">
    <h2>Producción Mensual</h2>

    <table>
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Empleado</th>
                <th>Prenda</th>
                <th>Cantidad</th>
                <th>Valor Total</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>2025-04-01</td>
                <td>Carlos Martínez</td>
                <td>Camisa</td>
                <td>50</td>
                <td>$25.000</td>
            </tr>
            <tr>
                <td>2025-04-03</td>
                <td>Laura Pérez</td>
                <td>Pantalón</td>
                <td>40</td>
                <td>$28.000</td>
            </tr>
            <!-- Puedes generar más dinámicamente con datos reales -->
        </tbody>
    </table>

    <div class="resumen-total">
        Total del mes: $53.000
    </div>
</div>
