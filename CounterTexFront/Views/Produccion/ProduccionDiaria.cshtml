@model CounterTexFront.Models.viewmodels.ProduccionDiariaViewModel

@{
    ViewBag.Title = "Producción Diaria";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Registrar Producción Diaria</h2>

@using (Html.BeginForm("ProduccionDiaria", "Produccion", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

    <div class="form-group">
        @Html.LabelFor(m => m.Fecha)
        @Html.TextBoxFor(m => m.Fecha, new { @class = "form-control", type = "date" })
        @Html.ValidationMessageFor(m => m.Fecha)
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.PrendaId)
        @Html.TextBoxFor(m => m.PrendaId, new { @class = "form-control", placeholder = "ID de la prenda" })
        @Html.ValidationMessageFor(m => m.PrendaId)
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.TotalValor)
        @Html.TextBoxFor(m => m.TotalValor, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.TotalValor)
    </div>

    <button type="submit" class="btn btn-primary">Guardar Producción</button>
}
