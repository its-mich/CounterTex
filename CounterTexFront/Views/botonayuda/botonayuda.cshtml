
@{
    ViewBag.Title = "View";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ayuda</title>

    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <style>

        body {
            background: #f5f5f5;
            font-family: Arial, sans-serif;
        }

        .sidebar {
            background: #343a40;
            color: #fff;
            min-height: 100vh;
            padding: 20px;
        }

            .sidebar .perfil .form-control {
                background: #495057;
                color: #fff;
                border: none;
            }

            .sidebar a {
                color: #ccc;
                transition: all 0.3s ease;
            }

                .sidebar a:hover {
                    color: #fff;
                }

                .sidebar a.btn {
                    display: block;
                    margin-bottom: 10px;
                    background: #495057;
                    border: none;
                    border-radius: 5px;
                    color: #ccc;
                    padding: 10px;
                    text-align: left;
                }

                    .sidebar a.btn:hover {
                        background: #4a0356;
                        color: #fff;
                    }

        .main-content {
            background: #fff;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
        }

        .header a {
            font-weight: bold;
            color: #f700ff;
            margin-left: 10px;
            text-decoration: none;
        }

            .header a:hover {
                text-decoration: underline;
            }

        .formulario {
            background: #ffffff;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
        }

            .formulario .tabs a {
                text-align: center;
                color: #fff;
                background: #f700ff;
                margin-right: 5px;
                border-radius: 5px;
                padding: 10px 20px;
                text-decoration: none;
            }

                .formulario .tabs a:hover {
                    background: #4a0356;
                }

            .formulario label {
                font-weight: bold;
                margin-bottom: 5px;
                display: block;
            }

            .formulario select,
            .formulario input[type="radio"],
            .formulario button {
                width: 100%;
                padding: 10px;
                border-radius: 5px;
                border: 1px solid #ccc;
            }

        body {
            margin: 0;
            padding: 0;
            background-image: url('fondo.jpg');
            background-size: cover;
            background-position: center;
            font-family: sans-serif;
        }

        .formulario button {
            background: #f700ff;
            color: #fff;
            font-weight: bold;
            cursor: pointer;
        }

            .formulario button:hover {
                background: #4a0356;
            }

        .formulario .form-check-label {
            font-weight: normal;
        }
    </style>
</head>
<body>
    <div class="container-fluid d-flex">
        <div class="sidebar">
            <div class="perfil mb-4">
                <div class="icono-perfil font-weight-bold mb-3">Perfil</div>
                <select name="empleado" id="empleado" class="form-control mb-3">
                    <option value="empleado">Empleado</option>
                    <option value="editar">Editar Perfil</option>
                    <option value="cerrar">Cerrar Sesión</option>
                </select>
            </div>
            <nav>
                <ul class="list-unstyled">
                    <li><a href="tipo-operacion.html" class="btn">Producción Diaria</a></li>
                    <li><a href="consultarinformacion.html" class="btn">Consultar Información</a></li>
                    <li><a href="controlhorarios.html" class="btn">Control de Horarios</a></li>
                    <li><a href="meta-por-corte.html" class="btn">Meta Por Corte</a></li>
                    <li><a href="boton-de-ayuda.html" class="btn active">Botón de Ayuda</a></li>
                    <li><a href="chatinterno.html" class="btn">Chat Interno</a></li>
                </ul>
            </nav>
        </div>
        <div class="main-content">
            <div class="header d-flex justify-content-end mb-4">
                <a href="Index.html">Inicio</a> |
                <a href="contacto.html">?</a>
            </div>
            <div class="formulario">
                <h2 class="text-center mb-4">¿Necesitas ayuda?</h2>
                <div class="d-grid">
                    <button class="btn btn-success" id="contactarSoporte">Contactar Soporte</button>
                </div>
            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>


    <script>

        document.getElementById('empleado').addEventListener('change', function () {
            if (!confirm('¿Desea cambiar su perfil a Empleado?')) {
                this.value = "empleado";
            }
        });


        document.getElementById('contactarSoporte').addEventListener('click', function () {
            alert('Se ha contactado con soporte. Un agente le asistirá pronto.');
        });

        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('click', function () {
                document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));
                this.classList.add('active');
            });
        });

        document.querySelectorAll('.nav-link').forEach(link => {
            link.addEventListener('mouseenter', function (event) {
                const tooltip = document.createElement('div');
                tooltip.className = 'tooltip';
                tooltip.innerText = `Ir a ${this.innerText}`;
                document.body.appendChild(tooltip);
                tooltip.style.position = 'absolute';
                tooltip.style.left = `${event.pageX + 5}px`;
                tooltip.style.top = `${event.pageY + 5}px`;


                this.addEventListener('mouseleave', function () {
                    tooltip.remove();
                });
            });
        });
    </script>
</body>
</html>

